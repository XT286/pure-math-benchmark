{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/XT286/pure-math-benchmark/blob/main/benchmark/schema/query-rubric-review.schema.json",
  "title": "PureMathBenchmarkQueryRubricReview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_id",
    "query_id",
    "rubric_id",
    "owning_area_code",
    "review_round",
    "recommendation",
    "checks",
    "requested_changes",
    "summary",
    "submitted_at"
  ],
  "properties": {
    "review_id": { "type": "string" },
    "query_id": {
      "type": "string",
      "pattern": "^PMB-[A-Z]{3,6}-[0-9]{4}-[0-9]{4}$"
    },
    "rubric_id": { "type": "string" },
    "owning_area_code": {
      "type": "string",
      "pattern": "^[0-9]{2}[A-Z]xx$"
    },
    "review_round": {
      "type": "integer",
      "minimum": 1
    },
    "recommendation": {
      "type": "string",
      "enum": ["accept", "minor_revision", "major_revision", "reject"]
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_elements_are_sufficient",
        "fatal_errors_are_field_appropriate",
        "partial_credit_guidance_is_usable",
        "alternate_valid_approaches_are_underdescribed"
      ],
      "properties": {
        "required_elements_are_sufficient": { "type": "boolean" },
        "fatal_errors_are_field_appropriate": { "type": "boolean" },
        "partial_credit_guidance_is_usable": { "type": "boolean" },
        "alternate_valid_approaches_are_underdescribed": { "type": "boolean" }
      }
    },
    "requested_changes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "summary": {
      "type": "string"
    },
    "legacy_source_review_id": {
      "type": "string"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
