{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/XT286/pure-math-benchmark/blob/main/benchmark/schema/rubric.schema.json",
  "title": "PureMathBenchmarkRubric",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rubric_id",
    "query_id",
    "owning_area_code",
    "rubric_basis",
    "rubric_focus",
    "success_criteria",
    "required_elements",
    "alternate_valid_approaches",
    "fatal_errors",
    "partial_credit_guidance"
  ],
  "properties": {
    "rubric_id": {
      "type": "string"
    },
    "query_id": {
      "type": "string",
      "pattern": "^PMB-[A-Z]{3,6}-[0-9]{4}-[0-9]{4}$"
    },
    "owning_area_code": {
      "type": "string",
      "pattern": "^[0-9]{2}[A-Z]xx$"
    },
    "rubric_basis": {
      "type": "string"
    },
    "rubric_focus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["problem_type", "answer_format", "primary_metric", "secondary_metrics"],
      "properties": {
        "problem_type": { "type": "string" },
        "answer_format": { "type": "string" },
        "primary_metric": { "type": "string" },
        "secondary_metrics": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "success_criteria": {
      "type": "string"
    },
    "required_elements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "alternate_valid_approaches": {
      "type": "array",
      "items": { "type": "string" }
    },
    "fatal_errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "partial_credit_guidance": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
