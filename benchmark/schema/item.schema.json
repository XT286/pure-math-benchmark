{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/XT286/pure-math-benchmark/blob/main/benchmark/schema/item.schema.json",
  "title": "PureMathBenchmarkQuery",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "status",
    "benchmark_track",
    "title",
    "primary_msc_code",
    "primary_msc_path",
    "secondary_msc_codes",
    "secondary_msc_paths",
    "owning_area_code",
    "eligible_reviewer_area_codes",
    "difficulty",
    "problem_type",
    "answer_format",
    "statement",
    "goal",
    "source",
    "novelty_and_leakage",
    "release",
    "legacy_record"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^PMB-[A-Z]{3,6}-[0-9]{4}-[0-9]{4}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "query_reviewed",
        "rubric_reviewed",
        "query_and_rubric_reviewed",
        "released",
        "deprecated",
        "retracted"
      ]
    },
    "benchmark_track": {
      "type": "string",
      "enum": ["broad_msc_math", "pure_math", "adjacent_theory", "cross_disciplinary"]
    },
    "title": {
      "type": "string"
    },
    "primary_msc_code": {
      "type": "string",
      "pattern": "^[0-9]{2}[A-Z][0-9]{2}$"
    },
    "primary_msc_path": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "string" }
    },
    "secondary_msc_codes": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9]{2}[A-Z][0-9]{2}$" }
    },
    "secondary_msc_paths": {
      "type": "array",
      "items": {
        "type": "array",
        "minItems": 3,
        "maxItems": 3,
        "items": { "type": "string" }
      }
    },
    "owning_area_code": {
      "type": "string",
      "pattern": "^[0-9]{2}[A-Z]xx$"
    },
    "owning_editor_id": {
      "type": "string"
    },
    "eligible_reviewer_area_codes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "cross_area_owner_codes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "difficulty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "reviewer_score"],
      "properties": {
        "stage": {
          "type": "string",
          "enum": ["advanced_graduate", "phd", "postdoc", "expert"]
        },
        "reviewer_score": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        }
      }
    },
    "problem_type": {
      "type": "string",
      "enum": [
        "proof",
        "proof_strategy",
        "counterexample",
        "construction",
        "classification",
        "theorem_applicability",
        "hypothesis_sensitivity",
        "framework_comparison",
        "invariant_interpretation"
      ]
    },
    "answer_format": {
      "type": "string",
      "enum": [
        "long_form_proof",
        "proof_outline",
        "short_justification",
        "structured_bullets",
        "construction_with_justification",
        "counterexample_with_justification"
      ]
    },
    "statement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "body", "notation_conventions", "prerequisites_assumed"],
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "notation_conventions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "definitions_included": { "type": "boolean" },
        "prerequisites_assumed": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["success_criteria"],
      "properties": {
        "success_criteria": { "type": "string" },
        "forbidden_shortcuts": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "citation", "license_status"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": ["journal", "monograph", "lecture_notes", "commissioned", "original_benchmark_item"]
        },
        "citation": { "type": "string" },
        "year": { "type": "integer" },
        "license_status": {
          "type": "string",
          "enum": ["cleared", "public_domain", "original", "restricted", "pending"]
        },
        "provenance_notes": { "type": "string" }
      }
    },
    "novelty_and_leakage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public_on_web", "generated_by_model", "contamination_risk", "leakage_check_completed"],
      "properties": {
        "public_on_web": {
          "type": "string",
          "enum": ["none_known", "limited", "moderate", "high"]
        },
        "generated_by_model": { "type": "boolean" },
        "contamination_risk": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "leakage_check_completed": { "type": "boolean" }
      }
    },
    "legacy_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["split", "previous_schema_taxonomy", "previous_review_summary_embedded"],
      "properties": {
        "split": { "type": "string" },
        "previous_schema_taxonomy": { "type": "object" },
        "previous_review_summary_embedded": { "type": "object" }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["first_release", "item_hash"],
      "properties": {
        "first_release": { "type": "string" },
        "item_hash": { "type": "string" }
      }
    }
  }
}
