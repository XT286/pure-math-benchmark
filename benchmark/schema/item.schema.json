{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/XT286/pure-math-benchmark/blob/main/benchmark/schema/item.schema.json",
  "title": "PureMathBenchmarkItem",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "status",
    "split",
    "taxonomy",
    "msc2020_codes",
    "difficulty",
    "problem_type",
    "answer_format",
    "statement",
    "goal",
    "source",
    "novelty_and_leakage",
    "ground_truth",
    "evaluation",
    "review",
    "release"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^PMB-[A-Z]{3,6}-[0-9]{4}-[0-9]{4}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "under_review", "accepted", "deprecated", "retracted"]
    },
    "split": {
      "type": "string",
      "enum": ["examples", "public_dev", "public_seed", "heldout_eval"]
    },
    "taxonomy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject_family", "subfield", "finer_topic"],
      "properties": {
        "subject_family": { "type": "string" },
        "subfield": { "type": "string" },
        "finer_topic": { "type": "string" },
        "secondary_tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cross_field_tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "msc2020_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[0-9]{2}[A-Z]?[0-9A-Z]{2,3}$"
      }
    },
    "difficulty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "reviewer_score"],
      "properties": {
        "stage": {
          "type": "string",
          "enum": ["advanced_graduate", "phd", "postdoc", "expert"]
        },
        "reviewer_score": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        }
      }
    },
    "problem_type": {
      "type": "string",
      "enum": [
        "proof",
        "proof_strategy",
        "counterexample",
        "construction",
        "classification",
        "theorem_applicability",
        "hypothesis_sensitivity",
        "framework_comparison",
        "invariant_interpretation"
      ]
    },
    "answer_format": {
      "type": "string",
      "enum": [
        "long_form_proof",
        "proof_outline",
        "short_justification",
        "structured_bullets",
        "construction_with_justification",
        "counterexample_with_justification"
      ]
    },
    "statement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "body", "notation_conventions", "prerequisites_assumed"],
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "notation_conventions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "definitions_included": { "type": "boolean" },
        "prerequisites_assumed": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["success_criteria"],
      "properties": {
        "success_criteria": { "type": "string" },
        "forbidden_shortcuts": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "citation", "license_status"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": ["journal", "monograph", "lecture_notes", "commissioned", "original_benchmark_item"]
        },
        "citation": { "type": "string" },
        "year": { "type": "integer" },
        "license_status": {
          "type": "string",
          "enum": ["cleared", "public_domain", "original", "restricted", "pending"]
        },
        "provenance_notes": { "type": "string" }
      }
    },
    "novelty_and_leakage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public_on_web", "generated_by_model", "contamination_risk", "leakage_check_completed"],
      "properties": {
        "public_on_web": {
          "type": "string",
          "enum": ["none_known", "limited", "moderate", "high"]
        },
        "generated_by_model": { "type": "boolean" },
        "contamination_risk": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "leakage_check_completed": { "type": "boolean" }
      }
    },
    "ground_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonical_solution_id", "proof_outline_available", "independent_verification_count"],
      "properties": {
        "canonical_solution_id": { "type": "string" },
        "proof_outline_available": { "type": "boolean" },
        "formalization_status": {
          "type": "string",
          "enum": ["none", "partial", "formalized"]
        },
        "independent_verification_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rubric_id", "primary_metric"],
      "properties": {
        "rubric_id": { "type": "string" },
        "primary_metric": {
          "type": "string",
          "enum": ["correctness", "argument_quality", "adjudicated_acceptability"]
        },
        "secondary_metrics": {
          "type": "array",
          "items": { "type": "string" }
        },
        "estimated_expert_time_minutes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["conflicts_checked", "review_rounds"],
      "properties": {
        "handling_editor": { "type": "string" },
        "reviewers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "conflicts_checked": { "type": "boolean" },
        "review_rounds": {
          "type": "integer",
          "minimum": 0
        },
        "last_reviewed_at": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "notes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ambiguity_risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "common_failure_modes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["first_release", "item_hash"],
      "properties": {
        "first_release": { "type": "string" },
        "item_hash": { "type": "string" }
      }
    }
  }
}
