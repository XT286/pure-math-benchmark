{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/XT286/pure-math-benchmark/blob/main/benchmark/schema/review.schema.json",
  "title": "PureMathBenchmarkReview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_id",
    "item_id",
    "review_round",
    "reviewer_role",
    "recommendation",
    "dimension_scores",
    "fatal_flaw",
    "text_justification",
    "conflicts_declared",
    "submitted_at"
  ],
  "properties": {
    "review_id": {
      "type": "string",
      "pattern": "^REV-[0-9]{4}-[0-9]{4}$"
    },
    "item_id": {
      "type": "string",
      "pattern": "^PMB-[A-Z]{3,6}-[0-9]{4}-[0-9]{4}$"
    },
    "review_round": {
      "type": "integer",
      "minimum": 1
    },
    "reviewer_role": {
      "type": "string",
      "enum": ["reviewer", "handling_editor", "adjudicator"]
    },
    "recommendation": {
      "type": "string",
      "enum": [
        "accept",
        "minor_revision",
        "major_revision",
        "reject",
        "deprecate",
        "retract"
      ]
    },
    "dimension_scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "main_claim_correctness",
        "logical_validity",
        "use_of_hypotheses",
        "completeness",
        "proof_strategy_quality",
        "partial_progress_value",
        "communication_clarity"
      ],
      "properties": {
        "main_claim_correctness": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "logical_validity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "use_of_hypotheses": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "completeness": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "proof_strategy_quality": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "partial_progress_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "communication_clarity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        }
      }
    },
    "fatal_flaw": { "type": "boolean" },
    "fatal_flaw_summary": { "type": "string" },
    "gap_locations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "strengths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "text_justification": { "type": "string" },
    "conflicts_declared": { "type": "boolean" },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
