{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/XT286/pure-math-benchmark/blob/main/benchmark/schema/candidate-seed-batch.schema.json",
  "title": "PureMathBenchmarkCandidateSeedBatch",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "seeds"],
  "properties": {
    "schema_version": {
      "type": "integer"
    },
    "seeds": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "msc_code",
          "source_id",
          "title",
          "statement_body",
          "success_criteria",
          "outline_summary"
        ],
        "properties": {
          "msc_code": {
            "type": "string",
            "pattern": "^[0-9]{2}[A-Z][0-9]{2}$"
          },
          "source_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "benchmark_track": {
            "type": "string",
            "enum": ["broad_msc_math", "pure_math", "adjacent_theory", "cross_disciplinary"]
          },
          "difficulty_stage": {
            "type": "string",
            "enum": ["advanced_graduate", "phd", "postdoc", "expert"]
          },
          "reviewer_score": {
            "type": "number",
            "minimum": 1,
            "maximum": 5
          },
          "problem_type": {
            "type": "string",
            "enum": [
              "proof",
              "proof_strategy",
              "counterexample",
              "construction",
              "classification",
              "theorem_applicability",
              "hypothesis_sensitivity",
              "framework_comparison",
              "invariant_interpretation"
            ]
          },
          "answer_format": {
            "type": "string",
            "enum": [
              "long_form_proof",
              "proof_outline",
              "short_justification",
              "structured_bullets",
              "construction_with_justification",
              "counterexample_with_justification"
            ]
          },
          "statement_body": {
            "type": "string"
          },
          "notation_conventions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "prerequisites_assumed": {
            "type": "array",
            "items": { "type": "string" }
          },
          "success_criteria": {
            "type": "string"
          },
          "required_elements": {
            "type": "array",
            "items": { "type": "string" }
          },
          "alternate_valid_approaches": {
            "type": "array",
            "items": { "type": "string" }
          },
          "fatal_errors": {
            "type": "array",
            "items": { "type": "string" }
          },
          "partial_credit_guidance": {
            "type": "array",
            "items": { "type": "string" }
          },
          "outline_summary": {
            "type": "string"
          },
          "required_ingredients": {
            "type": "array",
            "items": { "type": "string" }
          },
          "common_failure_modes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "provenance_notes": {
            "type": "string"
          },
          "public_on_web": {
            "type": "string",
            "enum": ["none_known", "limited", "moderate", "high"]
          },
          "contamination_risk": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        }
      }
    }
  }
}
