---
import BaseLayout from "../layouts/BaseLayout.astro";
import MscNavigator from "../components/MscNavigator.astro";
import { getCatalog } from "../lib/catalog.js";

const catalog = getCatalog();
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title="Pure Math Benchmark Catalog">
  <section class="hero">
    <h2 style="margin-top:0;">Browse benchmark queries by official MSC area</h2>
    <p class="muted">
      This catalog is designed so mathematicians can go directly to their field,
      inspect the current benchmark queries, and review the answer rubric attached
      to each query.
    </p>
    <div class="grid" style="margin-top:18px;">
      <div class="card">
        <strong>{catalog.counts.sections}</strong>
        <div class="muted">MSC sections indexed</div>
      </div>
      <div class="card">
        <strong>{catalog.counts.msc_nodes}</strong>
        <div class="muted">Official MSC nodes imported</div>
      </div>
      <div class="card">
        <strong>{catalog.counts.queries}</strong>
        <div class="muted">Queries currently migrated</div>
      </div>
      <div class="card">
        <strong>{catalog.counts.reviewed_queries}</strong>
        <div class="muted">Queries with both area and rubric review artifacts</div>
      </div>
    </div>
  </section>

  <MscNavigator
    title="Start by field"
    description="Pick level 1, then level 2, then the leaf code for your area. Once you reach the field you care about, the matching queries and rubric links appear below."
    idPrefix="home-nav"
  />

  <h2 class="section-title">What experts can do here</h2>
  <div class="grid">
    <div class="card">
      <h3 style="margin-top:0;">Review queries</h3>
      <p class="muted">Check whether a query is sound, well classified, and appropriate for your area.</p>
    </div>
    <div class="card">
      <h3 style="margin-top:0;">Review rubrics</h3>
      <p class="muted">Inspect how answers are judged, including fatal errors, acceptable approaches, and partial credit guidance.</p>
    </div>
    <div class="card">
      <h3 style="margin-top:0;">Suggest coverage</h3>
      <p class="muted">See where benchmark coverage is thin and propose stronger field-specific additions.</p>
    </div>
  </div>
  <p class="muted" style="margin-top:18px;">
    Prefer the direct field selector above, or browse the full MSC index at
    <a href={`${basePath}/msc/`}>the MSC page</a>.
  </p>
</BaseLayout>
