---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MscNavigator from "../../components/MscNavigator.astro";
---

<BaseLayout title="MSC Browse">
  <div class="breadcrumbs">Home / MSC</div>
  <section class="hero">
    <h2 style="margin-top:0;">Official MSC2020 browse</h2>
    <p class="muted">
      Each section page routes to its subclasses, visible queries, and participation paths for experts in that field.
    </p>
  </section>

  <MscNavigator
    title="MSC field selector"
    description="Use the dropdowns to narrow from section to subclass to leaf code. This keeps the browse experience focused and lets reviewers go straight to their own area."
    idPrefix="msc-nav"
  />
</BaseLayout>
