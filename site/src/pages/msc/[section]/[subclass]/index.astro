---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import QueryCard from "../../../../components/QueryCard.astro";
import { getCatalog, getChildren, getNodeByCode, getQueriesForCode } from "../../../../lib/catalog.js";

export function getStaticPaths() {
  const catalog = getCatalog();
  const paths = [];
  for (const section of catalog.sections) {
    const sectionNode = getNodeByCode(section.code);
    for (const subclass of getChildren(sectionNode)) {
      paths.push({
        params: {
          section: section.short_code,
          subclass: subclass.short_code,
        },
      });
    }
  }
  return paths;
}

const { section, subclass } = Astro.params;
const node = getNodeByCode(`${subclass}xx`);
const leafNodes = getChildren(node);
const queries = getQueriesForCode(node.code);
---

<BaseLayout title={`${subclass} | MSC`}>
  <div class="breadcrumbs">
    Home / <a href="/msc/">MSC</a> / <a href={`/msc/${section}/`}>{section}</a> / {subclass}
  </div>

  <section class="hero">
    <h2 style="margin-top:0;">{node.short_code} {node.label}</h2>
    <p class="muted">
      Owning-area page for experts in <code>{node.code}</code>. Review here focuses on the
      query itself and the rubric used to judge answers in this area.
    </p>
  </section>

  <h2 class="section-title">Leaf codes</h2>
  <div class="grid">
    {leafNodes.map((leaf) => (
      <a class="card" href={`/msc/${section}/${subclass}/${leaf.short_code}/`}>
        <strong>{leaf.short_code}</strong>
        <h3 style="margin:12px 0 8px;">{leaf.label}</h3>
        <div class="muted">{getQueriesForCode(leaf.code).length} visible queries</div>
      </a>
    ))}
  </div>

  <h2 class="section-title">Visible queries in this area</h2>
  <div class="list">
    {queries.length > 0 ? queries.map((query) => <QueryCard query={query} />) : <div class="card">No public queries in this subclass yet.</div>}
  </div>
</BaseLayout>
