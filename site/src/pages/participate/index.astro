---
import BaseLayout from "../../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Participate">
  <div class="breadcrumbs">Home / <a href={base}>Catalog</a> / Participate</div>

  <section class="hero">
    <h2 style="margin-top:0;">How mathematicians should participate</h2>
    <p class="muted">
      The primary contribution path is no longer generic benchmark feedback. Experts are invited to review
      queries and answer rubrics in their own MSC area.
    </p>
  </section>

  <div class="grid">
    <div class="card">
      <h3 style="margin-top:0;">Review a query</h3>
      <p class="muted">Confirm that the query is mathematically sound, properly classified, and genuinely representative of the area.</p>
    </div>
    <div class="card">
      <h3 style="margin-top:0;">Review the answer rubric</h3>
      <p class="muted">Check whether the rubric correctly identifies valid approaches, fatal errors, and partial-credit boundaries.</p>
    </div>
    <div class="card">
      <h3 style="margin-top:0;">Help expand coverage</h3>
      <p class="muted">Use the MSC browse pages to identify thin areas and propose stronger query/rubric pairs for those codes.</p>
    </div>
  </div>
</BaseLayout>
