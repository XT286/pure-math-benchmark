---
const { title = "Pure Math Benchmark Catalog", description = "Browse MSC areas, benchmark queries, and answer rubrics." } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        color-scheme: light dark;
        --bg: #0b1020;
        --panel: #151c30;
        --panel-soft: #1d2743;
        --text: #edf2ff;
        --muted: #b8c2db;
        --accent: #8ab4ff;
        --border: #314162;
      }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--text);
      }
      a {
        color: var(--accent);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .shell {
        max-width: 1180px;
        margin: 0 auto;
        padding: 24px;
      }
      header {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
      }
      nav {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
      }
      .hero,
      .card,
      .list-item {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
      }
      .hero {
        padding: 24px;
        margin-bottom: 24px;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 16px;
      }
      .card {
        padding: 18px;
      }
      .list {
        display: grid;
        gap: 12px;
      }
      .list-item {
        padding: 16px;
      }
      .muted {
        color: var(--muted);
      }
      .badge-row {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin: 8px 0 0;
      }
      .badge {
        display: inline-block;
        padding: 3px 8px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: var(--panel-soft);
        font-size: 0.82rem;
      }
      .section-title {
        margin: 32px 0 12px;
      }
      .breadcrumbs {
        margin: 0 0 18px;
        color: var(--muted);
      }
      code {
        font-family: ui-monospace, SFMono-Regular, SF Mono, Menlo, monospace;
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header>
        <div>
          <h1 style="margin:0;font-size:1.6rem;"><a href={`${basePath}/`}>Pure Math Benchmark Catalog</a></h1>
          <div class="muted">MSC-directed query and rubric browsing for expert contributors</div>
        </div>
        <nav>
          <a href={`${basePath}/msc/`}>MSC browse</a>
          <a href={`${basePath}/participate/`}>Participate</a>
          <a href="https://github.com/XT286/pure-math-benchmark">Repository</a>
        </nav>
      </header>
      <slot />
    </div>
  </body>
 </html>
