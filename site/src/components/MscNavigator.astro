---
import { getCatalog, getCandidateQueriesForCode, getNodeByCode, getQueriesForCode } from "../lib/catalog.js";

const {
  title = "Find your field",
  description = "Select an MSC section, subclass, and leaf code to see the relevant queries and rubrics.",
  idPrefix = "msc-nav",
} = Astro.props;

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const catalog = getCatalog();
const sections = catalog.sections.map((section) => ({
  code: section.code,
  shortCode: section.short_code,
  label: section.label,
  canonicalQueryCount: section.canonical_query_count ?? section.query_count ?? 0,
  candidateQueryCount: section.candidate_query_count ?? 0,
  totalQueryCount: section.total_query_count ?? section.query_count ?? 0,
}));

const subclasses = sections.flatMap((section) => {
  const sectionNode = getNodeByCode(section.code);
  return sectionNode.child_codes
    .map((code) => getNodeByCode(code))
    .filter(Boolean)
    .map((node) => ({
      code: node.code,
      shortCode: node.short_code,
      label: node.label,
      parentCode: section.code,
      canonicalQueryCount: getQueriesForCode(node.code).length,
      candidateQueryCount: getCandidateQueriesForCode(node.code).length,
      totalQueryCount: getQueriesForCode(node.code).length + getCandidateQueriesForCode(node.code).length,
    }));
});

const leaves = subclasses.flatMap((subclass) => {
  const subclassNode = getNodeByCode(subclass.code);
  return subclassNode.child_codes
    .map((code) => getNodeByCode(code))
    .filter(Boolean)
    .map((node) => ({
      code: node.code,
      shortCode: node.short_code,
      label: node.label,
      parentCode: subclass.code,
      canonicalQueryCount: getQueriesForCode(node.code).filter((query) => query.primary_msc_code === node.code).length,
      candidateQueryCount: getCandidateQueriesForCode(node.code).filter((query) => query.primary_msc_code === node.code).length,
      totalQueryCount:
        getQueriesForCode(node.code).filter((query) => query.primary_msc_code === node.code).length +
        getCandidateQueriesForCode(node.code).filter((query) => query.primary_msc_code === node.code).length,
    }));
});

const queryIndex = leaves.map((leaf) => {
  const canonicalQueries = getQueriesForCode(leaf.code).filter((query) => query.primary_msc_code === leaf.code);
  const candidateQueries = getCandidateQueriesForCode(leaf.code).filter((query) => query.primary_msc_code === leaf.code);
  return {
    leafCode: leaf.code,
    canonicalQueries: canonicalQueries.map((query) => ({
      id: query.id,
      title: query.title,
      status: query.status,
      problemType: query.problem_type,
      answerFormat: query.answer_format,
      routePath: query.route_path,
      layerLabel: "reviewed",
    })),
    candidateQueries: candidateQueries.map((query) => ({
      id: query.id,
      title: query.title,
      status: query.status,
      problemType: query.problem_type,
      answerFormat: query.answer_format,
      routePath: query.route_path,
      layerLabel: "candidate",
    })),
  };
});
---

<section class="card" style="padding:20px;">
  <h2 style="margin-top:0;">{title}</h2>
  <p class="muted">{description}</p>
  <p class="muted" style="margin-top:-4px;">
    The dropdowns show the full official MSC hierarchy. Counts distinguish reviewed benchmark items from draft candidate items.
  </p>

  <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));">
    <label class="card" style="padding:14px;">
      <strong>Level 1</strong>
      <div class="muted" style="margin:6px 0 10px;">MSC section</div>
      <select id={`${idPrefix}-section`} style="width:100%;padding:10px;border-radius:10px;border:1px solid var(--border);background:var(--panel-soft);color:var(--text);">
        <option value="">Choose section</option>
      </select>
    </label>
    <label class="card" style="padding:14px;">
      <strong>Level 2</strong>
      <div class="muted" style="margin:6px 0 10px;">MSC subclass</div>
      <select id={`${idPrefix}-subclass`} disabled style="width:100%;padding:10px;border-radius:10px;border:1px solid var(--border);background:var(--panel-soft);color:var(--text);">
        <option value="">Choose subclass</option>
      </select>
    </label>
    <label class="card" style="padding:14px;">
      <strong>Level 3</strong>
      <div class="muted" style="margin:6px 0 10px;">MSC leaf</div>
      <select id={`${idPrefix}-leaf`} disabled style="width:100%;padding:10px;border-radius:10px;border:1px solid var(--border);background:var(--panel-soft);color:var(--text);">
        <option value="">Choose leaf code</option>
      </select>
    </label>
  </div>

  <div id={`${idPrefix}-selection`} class="muted" style="margin-top:16px;"></div>
  <div id={`${idPrefix}-results`} class="list" style="margin-top:16px;"></div>
</section>

<script
  define:vars={{
    idPrefix,
    basePath,
    sections,
    subclasses,
    leaves,
    queryIndex,
  }}
>
  const sectionSelect = document.getElementById(`${idPrefix}-section`);
  const subclassSelect = document.getElementById(`${idPrefix}-subclass`);
  const leafSelect = document.getElementById(`${idPrefix}-leaf`);
  const selection = document.getElementById(`${idPrefix}-selection`);
  const results = document.getElementById(`${idPrefix}-results`);

  function resetSelect(select, placeholder) {
    select.innerHTML = "";
    const option = document.createElement("option");
    option.value = "";
    option.textContent = placeholder;
    select.appendChild(option);
    select.value = "";
  }

  function addOptions(select, items, formatter) {
    for (const item of items) {
      const option = document.createElement("option");
      option.value = item.code;
      option.textContent = formatter(item);
      select.appendChild(option);
    }
  }

  function renderResults() {
    const leafCode = leafSelect.value;
    results.innerHTML = "";

    if (!leafCode) {
      selection.textContent = "Select all three levels to view reviewed and candidate queries in that field.";
      return;
    }

    const section = sections.find((item) => item.code === sectionSelect.value);
    const subclass = subclasses.find((item) => item.code === subclassSelect.value);
    const leaf = leaves.find((item) => item.code === leafCode);
    selection.textContent = `${section.shortCode} ${section.label} -> ${subclass.shortCode} ${subclass.label} -> ${leaf.shortCode} ${leaf.label}`;

    const queryGroup = queryIndex.find((item) => item.leafCode === leafCode);
    if (!queryGroup) {
      results.innerHTML = `<div class="list-item">No visible content for this leaf code yet.</div>`;
      return;
    }

    const renderQuery = (query) => `
          <article class="list-item">
            <div style="display:flex;justify-content:space-between;gap:12px;align-items:flex-start;">
              <div>
                <h3 style="margin:0 0 8px;"><a href="${basePath}${query.routePath}">${query.title}</a></h3>
                <div class="muted"><code>${query.id}</code></div>
              </div>
              <span class="badge">${query.status}</span>
            </div>
            <div class="badge-row" style="margin-top:12px;">
              <span class="badge">${query.layerLabel}</span>
              <span class="badge">${query.problemType}</span>
              <span class="badge">${query.answerFormat}</span>
            </div>
          </article>
        `;

    const reviewedQueries = queryGroup.canonicalQueries ?? [];
    const candidateQueries = queryGroup.candidateQueries ?? [];

    if (reviewedQueries.length === 0 && candidateQueries.length === 0) {
      results.innerHTML = `<div class="list-item">No reviewed or candidate queries for this leaf code yet.</div>`;
      return;
    }

    const blocks = [];

    if (reviewedQueries.length > 0) {
      blocks.push(`
        <div class="list-item">
          <strong>Reviewed benchmark queries</strong>
          <div class="muted" style="margin-top:6px;">Canonical items in the expert-reviewed benchmark tree.</div>
        </div>
        ${reviewedQueries.map((query) => renderQuery(query)).join("")}
      `);
    }

    if (candidateQueries.length > 0) {
      blocks.push(`
        <div class="list-item">
          <strong>Draft candidate queries</strong>
          <div class="muted" style="margin-top:6px;">Publicly visible candidates that are not yet expert-reviewed benchmark items.</div>
        </div>
        ${candidateQueries.map((query) => renderQuery(query)).join("")}
      `);
    }

    results.innerHTML = blocks.join("");
  }

  resetSelect(sectionSelect, "Choose section");
  addOptions(sectionSelect, sections, (item) => `${item.shortCode} ${item.label} (${item.canonicalQueryCount} reviewed, ${item.candidateQueryCount} candidate)`);
  resetSelect(subclassSelect, "Choose subclass");
  resetSelect(leafSelect, "Choose leaf code");
  renderResults();

  sectionSelect.addEventListener("change", () => {
    const matchingSubclasses = subclasses.filter((item) => item.parentCode === sectionSelect.value);
    resetSelect(subclassSelect, "Choose subclass");
    resetSelect(leafSelect, "Choose leaf code");
    subclassSelect.disabled = matchingSubclasses.length === 0;
    leafSelect.disabled = true;
    addOptions(subclassSelect, matchingSubclasses, (item) => `${item.shortCode} ${item.label} (${item.canonicalQueryCount} reviewed, ${item.candidateQueryCount} candidate)`);
    renderResults();
  });

  subclassSelect.addEventListener("change", () => {
    const matchingLeaves = leaves.filter((item) => item.parentCode === subclassSelect.value);
    resetSelect(leafSelect, "Choose leaf code");
    leafSelect.disabled = matchingLeaves.length === 0;
    addOptions(leafSelect, matchingLeaves, (item) => `${item.shortCode} ${item.label} (${item.canonicalQueryCount} reviewed, ${item.candidateQueryCount} candidate)`);
    renderResults();
  });

  leafSelect.addEventListener("change", renderResults);
</script>
